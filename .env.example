# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL ENVIRONMENT VARIABLES
# ─────────────────────────────────────────────────────────────────────────────
# Note: EMBFinder is designed to run 100% locally with zero configuration.
# You only need to use these if you want to explicitly override the defaults.

# ── Go Server ────────────────────────────────────────────────────────────────
# PORT=8765                      # The port the web UI and Go API runs on
# DB_PATH=~/.embfinder/embfinder.db  # Where the SQLite metadata and index is saved

# ── Python Embedder ──────────────────────────────────────────────────────────
# EMBEDDER_PORT=8766             # The local port for the Python subprocess
# EMBEDDER_URL=http://...        # Bypass subprocess and use an external AI server
# CLIP_MODEL=MobileCLIP-B      # Advanced: Override the Vision model used
# CLIP_PRETRAINED=datacompdr   # Advanced: Override the weights source

# ── Integrations ─────────────────────────────────────────────────────────────
# EMB_ENGINE_URL=http://localhost:8767 # Optional URL if running a custom EmbEngine server
