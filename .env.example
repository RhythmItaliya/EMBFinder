# EMBFinder — Master Configuration Template
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this to .env and adjust paths for your system.

MODE=development
EMB_LIB=/path/to/your/embroidery_library
DB_PATH=./go-server/data/embfinder.db

HOST=127.0.0.1
PORT=8765

EMBEDDER_HOST=127.0.0.1
EMBEDDER_PORT=8766

EMB_ENGINE_URL=http://127.0.0.1:8767

CLIP_MODEL=MobileCLIP-B
CLIP_PRETRAINED=datacompdr

MAX_WORKERS=4
LOG_LEVEL=debug
