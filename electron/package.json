{
  "name": "embfinder",
  "version": "1.0.0",
  "author": "RhythmItaliya",
  "homepage": "https://github.com/RhythmItaliya/EMBFinder",
  "description": "EMBFinder - Embroidery Visual Search",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux deb"
  },
  "build": {
    "appId": "com.embfinder.app",
    "productName": "EMBFinder",
    "copyright": "Copyright © 2026 RhythmItaliya",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../go-server/embfinder",
        "to": "embfinder",
        "filter": ["**/*"]
      },
      {
        "from": "../go-server/embfinder.exe",
        "to": "embfinder.exe",
        "filter": ["**/*"]
      },
      {
        "from": "../embedder",
        "to": "embedder",
        "filter": ["**/*", "!**/__pycache__", "!**/.venv"]
      }
    ],
    "publish": null,
    "win": {
      "target": ["nsis", "portable"],
      "verifyUpdateCodeSignature": false
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.graphics-design"
    },
    "linux": {
      "target": ["deb", "AppImage"],
      "category": "Graphics",
      "maintainer": "RhythmItaliya <rhythm@github.com>"
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  }
}
